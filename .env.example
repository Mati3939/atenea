# URL base de tu Canvas institucional (sin barra final)
CANVAS_URL=https://tu-universidad.instructure.com

# Token de acceso: Canvas → Cuenta → Configuración → Integraciones aprobadas → Nuevo token
CANVAS_TOKEN=tu_token_aqui

# ── Motor de IA ───────────────────────────────────────────────────────────────
# Atenea usa Groq (nube, gratis, ~1-3s y LaTeX limpio) si hay GROQ_API_KEY.
# Sin la key, cae automáticamente a Ollama (local). Crea una key gratis en:
#   https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Modelo de reserva en Groq si el primario agota su cupo (429, TPD/TPM) o falla.
# Tiene cupo propio en el free tier, así que amortigua antes de caer a Ollama.
# GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# Último eslabón de la cadena: si también falla el modelo de reserva, cae a
# Ollama local (salvo que lo desactives con OLLAMA_FALLBACK=0).
# OLLAMA_FALLBACK=1

# Forzar proveedor: "groq" u "ollama". Vacío = automático (groq si hay key).
LLM_PROVIDER=

# Modelo de Ollama (solo se usa si el proveedor activo es Ollama, o como
# último fallback si Groq y su modelo de reserva fallan).
# Debe estar descargado con: ollama pull <modelo>
OLLAMA_MODEL=llama3.2

# Sincronizar Canvas en segundo plano al arrancar la app (1 = sí, 0 = no).
AUTO_SYNC=1

# Cursos de Canvas a excluir por no ser ramos académicos (institucionales,
# genéricos, programas). Lista separada por comas de subcadenas que se buscan en
# el nombre y course_code (sin distinción de mayúsculas). Vacío = usa los defaults
# (concepcion_gen, viveudd, generico, estudiantes destacados, programa de estudiantes).
EXCLUDED_COURSES=

# Modelo de embeddings para la búsqueda semántica (ollama pull paraphrase-multilingual)
# Entiende español mucho mejor que el default de ChromaDB.
# Usa "default" para volver al embedding integrado de ChromaDB.
EMBEDDING_MODEL=paraphrase-multilingual

# URL del servidor Ollama (normalmente no hace falta cambiarla)
# OLLAMA_URL=http://localhost:11434
